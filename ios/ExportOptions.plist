<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 
      สำหรับ build แบบพัฒนา/ทดสอบ ใช้ "development" หรือ "ad-hoc"
      ถ้าต้องการอัปโหลด App Store / TestFlight ด้วยตนเอง ค่อยเปลี่ยนเป็น "app-store"
    -->
    <key>method</key>
    <string>development</string>

    <key>signingStyle</key>
    <string>automatic</string>

    <key>stripSwiftSymbols</key>
    <true/>

    <!-- 
      ถ้าใช้ Automatic code signing ใน Codemagic 
      สามารถเว้นว่าง teamID ได้
    -->
    <key>teamID</key>
    <string></string>
</dict>
</plist>